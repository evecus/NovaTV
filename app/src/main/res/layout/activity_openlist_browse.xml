<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="@dimen/vs_40"
    android:paddingTop="@dimen/vs_30"
    android:paddingRight="@dimen/vs_40"
    android:paddingBottom="@dimen/vs_30">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/vs_40"
                android:layout_height="@dimen/vs_40"
                android:src="@drawable/icon_openlist" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/vs_12"
                android:text="OpenList 网盘"
                android:textColor="@android:color/white"
                android:textSize="@dimen/ts_30"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/vs_15"
                android:background="@drawable/button_danmu_setting"
                android:focusable="true"
                android:gravity="center"
                android:paddingLeft="@dimen/vs_20"
                android:paddingTop="@dimen/vs_8"
                android:paddingRight="@dimen/vs_20"
                android:paddingBottom="@dimen/vs_8"
                android:text="回到主页"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_20"
                android:nextFocusRight="@id/tvLogout"
                android:nextFocusDown="@id/fileList" />

            <TextView
                android:id="@+id/tvLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/button_danmu_setting"
                android:focusable="true"
                android:gravity="center"
                android:paddingLeft="@dimen/vs_20"
                android:paddingTop="@dimen/vs_8"
                android:paddingRight="@dimen/vs_20"
                android:paddingBottom="@dimen/vs_8"
                android:text="退出登录"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_20"
                android:nextFocusLeft="@id/tvHome"
                android:nextFocusDown="@id/fileList" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_10"
            android:ellipsize="middle"
            android:singleLine="true"
            android:textColor="@color/color_CCFFFFFF"
            android:textSize="@dimen/ts_20" />

        <!-- 修复：添加 nextFocusUp 指向退出按钮 -->
        <com.owen.tvrecyclerview.widget.TvRecyclerView
            android:id="@+id/fileList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/vs_20"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:focusable="true"
            android:paddingBottom="@dimen/vs_10"
            android:scrollbars="none"
            android:nextFocusUp="@id/tvLogout" />

        <LinearLayout
            android:id="@+id/loadingRoot"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="@dimen/vs_50"
                android:layout_height="@dimen/vs_50" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_10"
            android:gravity="center"
            android:text="当前目录为空"
            android:textColor="@color/color_CCFFFFFF"
            android:textSize="@dimen/ts_22"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
