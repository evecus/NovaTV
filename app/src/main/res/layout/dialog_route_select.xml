<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_danmu_setting_bg"
        android:orientation="horizontal"
        android:padding="@dimen/vs_30">

        <!-- Left: Config entries -->
        <LinearLayout
            android:layout_width="@dimen/vs_300"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="配置列表"
                android:textColor="@color/dialog_text_primary"
                android:textStyle="bold"
                android:textSize="@dimen/ts_22"
                android:gravity="center"
                android:layout_marginBottom="@dimen/vs_10" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="@dimen/vs_400"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/llConfigList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="@dimen/vs_2"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/vs_15"
            android:layout_marginEnd="@dimen/vs_15"
            android:layout_marginLeft="@dimen/vs_15"
            android:layout_marginRight="@dimen/vs_15"
            android:background="#44FFFFFF" />

        <!-- Right: Routes -->
        <LinearLayout
            android:layout_width="@dimen/vs_300"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="线路列表"
                android:textColor="@color/dialog_text_primary"
                android:textStyle="bold"
                android:textSize="@dimen/ts_22"
                android:gravity="center"
                android:layout_marginBottom="@dimen/vs_10" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="@dimen/vs_400"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/llRouteList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
