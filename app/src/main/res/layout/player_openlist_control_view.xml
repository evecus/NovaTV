<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:id="@+id/openlistTopRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@android:color/transparent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/vs_40"
        android:paddingTop="@dimen/vs_20"
        android:paddingRight="@dimen/vs_40"
        android:paddingBottom="@dimen/vs_20"
        android:visibility="gone">

        <TextView
            android:id="@+id/openlistPlayTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@android:color/white"
            android:textSize="@dimen/ts_26"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- 中间 loading -->
    <ProgressBar
        android:id="@+id/openlistLoading"
        android:layout_width="@dimen/vs_60"
        android:layout_height="@dimen/vs_60"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- 中间暂停图标 -->
    <ImageView
        android:id="@+id/openlistPauseIcon"
        android:layout_width="@dimen/vs_80"
        android:layout_height="@dimen/vs_80"
        android:layout_gravity="center"
        android:alpha="0.85"
        android:src="@drawable/icon_play"
        android:visibility="gone" />

    <!-- 底部控制条 -->
    <LinearLayout
        android:id="@+id/openlistBottomRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/vs_40"
        android:paddingTop="@dimen/vs_15"
        android:paddingRight="@dimen/vs_40"
        android:paddingBottom="@dimen/vs_15"
        android:visibility="gone">

        <TextView
            android:id="@+id/openlistCurTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="@dimen/ts_20"
            tools:text="00:00" />

        <SeekBar
            android:id="@+id/openlistSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/vs_15"
            android:layout_marginRight="@dimen/vs_15"
            android:layout_weight="1"
            android:focusable="false"
            android:max="1000"
            android:maxHeight="@dimen/vs_4"
            android:minHeight="@dimen/vs_4"
            android:progressTint="@color/color_FF5F00"
            android:thumbTint="@color/color_FF5F00" />

        <TextView
            android:id="@+id/openlistTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="@dimen/ts_20"
            tools:text="00:00" />
    </LinearLayout>
</FrameLayout>
