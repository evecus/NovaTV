<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/topLayout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/vs_50"
        android:layout_marginTop="@dimen/vs_10"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/vs_50"
        android:paddingRight="@dimen/vs_50"
        android:paddingBottom="@dimen/vs_10"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 左侧：时间显示 -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:gravity="left|center_vertical"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textAlignment="gravity"
            android:textColor="@android:color/white"
            android:textSize="@dimen/ts_26"
            tools:text="7月3日  10:10" />

        <!-- 隐藏的tvName，保持代码兼容 -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="@dimen/vs_0"
            android:layout_height="@dimen/vs_0"
            android:visibility="gone" />

        <!-- 弹簧，把图标按钮推到右侧 -->
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- 右侧：8个图标按钮 -->
        <LinearLayout
            android:id="@+id/topIconBar"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/topBtnHistory"
                android:layout_width="@dimen/vs_60"
                android:layout_height="@dimen/vs_42"
                android:layout_marginLeft="@dimen/vs_4"
                android:background="@drawable/shape_user_focus"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="@dimen/vs_28"
                    android:layout_height="@dimen/vs_28"
                    android:alpha="0.85"
                    android:src="@drawable/icon_history" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/topBtnLive"
                android:layout_width="@dimen/vs_60"
                android:layout_height="@dimen/vs_42"
                android:layout_marginLeft="@dimen/vs_4"
                android:background="@drawable/shape_user_focus"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="@dimen/vs_28"
                    android:layout_height="@dimen/vs_28"
                    android:alpha="0.85"
                    android:src="@drawable/icon_live" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/topBtnSearch"
                android:layout_width="@dimen/vs_60"
                android:layout_height="@dimen/vs_42"
                android:layout_marginLeft="@dimen/vs_4"
                android:background="@drawable/shape_user_focus"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="@dimen/vs_28"
                    android:layout_height="@dimen/vs_28"
                    android:alpha="0.85"
                    android:src="@drawable/icon_search" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/topBtnPush"
                android:layout_width="@dimen/vs_60"
                android:layout_height="@dimen/vs_42"
                android:layout_marginLeft="@dimen/vs_4"
                android:background="@drawable/shape_user_focus"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="@dimen/vs_28"
                    android:layout_height="@dimen/vs_28"
                    android:alpha="0.85"
                    android:src="@drawable/icon_push" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/topBtnFavorite"
                android:layout_width="@dimen/vs_60"
                android:layout_height="@dimen/vs_42"
                android:layout_marginLeft="@dimen/vs_4"
                android:background="@drawable/shape_user_focus"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="@dimen/vs_28"
                    android:layout_height="@dimen/vs_28"
                    android:alpha="0.85"
                    android:src="@drawable/icon_collect" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/topBtnRouteLine"
                android:layout_width="@dimen/vs_60"
                android:layout_height="@dimen/vs_42"
                android:layout_marginLeft="@dimen/vs_4"
                android:background="@drawable/shape_user_focus"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="@dimen/vs_28"
                    android:layout_height="@dimen/vs_28"
                    android:alpha="0.85"
                    android:src="@drawable/icon_filter" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/topBtnOpenList"
                android:layout_width="@dimen/vs_60"
                android:layout_height="@dimen/vs_42"
                android:layout_marginLeft="@dimen/vs_4"
                android:background="@drawable/shape_user_focus"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="@dimen/vs_28"
                    android:layout_height="@dimen/vs_28"
                    android:alpha="0.85"
                    android:src="@drawable/icon_openlist" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/topBtnRoute"
                android:layout_width="@dimen/vs_60"
                android:layout_height="@dimen/vs_42"
                android:layout_marginLeft="@dimen/vs_4"
                android:background="@drawable/shape_user_focus"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="@dimen/vs_28"
                    android:layout_height="@dimen/vs_28"
                    android:alpha="0.85"
                    android:src="@drawable/icon_route" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/topBtnSetting"
                android:layout_width="@dimen/vs_60"
                android:layout_height="@dimen/vs_42"
                android:layout_marginLeft="@dimen/vs_4"
                android:background="@drawable/shape_user_focus"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="@dimen/vs_28"
                    android:layout_height="@dimen/vs_28"
                    android:alpha="0.85"
                    android:src="@drawable/icon_setting" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="@dimen/vs_0"
        android:layout_height="@dimen/vs_0"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topLayout">

        <com.owen.tvrecyclerview.widget.TvRecyclerView
            android:id="@+id/mGridView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_10"
            android:layout_marginBottom="@dimen/vs_10"
            android:paddingLeft="@dimen/vs_50"
            android:paddingRight="@dimen/vs_50"
            app:tv_selectedItemIsCentered="true" />

        <com.github.tvbox.osc.ui.tv.widget.NoScrollViewPager
            android:id="@+id/mViewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
