<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_danmu_setting_bg"
        android:orientation="horizontal"
        android:padding="@dimen/vs_35">

        <!-- Left: QR Code -->
        <LinearLayout
            android:layout_width="@dimen/vs_300"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="扫码远程推送"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_22"
                android:layout_marginBottom="@dimen/vs_5" />

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#88FFFFFF"
                android:textSize="@dimen/ts_20"
                android:layout_marginBottom="@dimen/vs_8" />

            <ImageView
                android:id="@+id/ivQRCode"
                android:layout_width="@dimen/vs_250"
                android:layout_height="@dimen/vs_250"
                android:focusable="false" />

            <TextView
                android:id="@+id/storagePermission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vs_12"
                android:background="@drawable/button_danmu_setting"
                android:focusable="true"
                android:gravity="center"
                android:padding="@dimen/vs_10"
                android:text="存储权限"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_22"
                android:nextFocusRight="@id/etName"
                android:nextFocusDown="@id/etName" />
        </LinearLayout>

        <!-- Right: Live source list + input -->
        <LinearLayout
            android:layout_width="@dimen/vs_600"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/vs_20"
            android:layout_marginLeft="@dimen/vs_20"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="直播地址配置"
                android:textColor="@color/dialog_text_primary"
                android:textStyle="bold"
                android:textSize="@dimen/ts_24"
                android:layout_marginBottom="@dimen/vs_12" />

            <!-- Source list -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="@dimen/vs_300"
                android:scrollbars="none"
                android:descendantFocusability="afterDescendants">

                <LinearLayout
                    android:id="@+id/llSourceList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="@dimen/vs_20"
                android:text="暂无直播源，请在下方添加"
                android:textColor="#88FFFFFF"
                android:textSize="@dimen/ts_22"
                android:visibility="gone" />

            <!-- Input area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vs_10"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="@dimen/vs_150"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/vs_5"
                    android:layout_marginRight="@dimen/vs_5"
                    android:background="@drawable/input_dialog_api_input"
                    android:hint="名称"
                    android:imeOptions="actionNext|flagNoExtractUi"
                    android:inputType="text"
                    android:maxLines="1"
                    android:focusable="true"
                    android:nextFocusLeft="@id/storagePermission"
                    android:nextFocusRight="@id/etUrl"
                    android:nextFocusUp="@id/storagePermission"
                    android:nextFocusDown="@id/etUrl"
                    android:nextFocusForward="@id/etUrl"
                    android:paddingLeft="@dimen/vs_5"
                    android:paddingTop="@dimen/vs_8"
                    android:paddingRight="@dimen/vs_5"
                    android:paddingBottom="@dimen/vs_8"
                    android:singleLine="true"
                    android:textColor="@color/dialog_text_primary"
                    android:textColorHint="@color/dialog_text_hint"
                    android:textSize="@dimen/ts_22" />

                <EditText
                    android:id="@+id/etUrl"
                    android:layout_width="@dimen/vs_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/vs_5"
                    android:layout_marginRight="@dimen/vs_5"
                    android:background="@drawable/input_dialog_api_input"
                    android:hint="直播地址"
                    android:imeOptions="actionDone|flagNoExtractUi"
                    android:inputType="text"
                    android:maxLines="1"
                    android:focusable="true"
                    android:nextFocusLeft="@id/etName"
                    android:nextFocusRight="@id/btnAdd"
                    android:nextFocusUp="@id/etName"
                    android:nextFocusDown="@id/btnAdd"
                    android:nextFocusForward="@id/btnAdd"
                    android:paddingLeft="@dimen/vs_5"
                    android:paddingTop="@dimen/vs_8"
                    android:paddingRight="@dimen/vs_5"
                    android:paddingBottom="@dimen/vs_8"
                    android:singleLine="true"
                    android:textColor="@color/dialog_text_primary"
                    android:textColorHint="@color/dialog_text_hint"
                    android:textSize="@dimen/ts_22" />

                <TextView
                    android:id="@+id/btnAdd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_danmu_setting"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingLeft="@dimen/vs_20"
                    android:paddingTop="@dimen/vs_8"
                    android:paddingRight="@dimen/vs_20"
                    android:paddingBottom="@dimen/vs_8"
                    android:text="确定"
                    android:textColor="@color/dialog_text_primary"
                    android:textSize="@dimen/ts_22"
                    android:nextFocusLeft="@id/etUrl"
                    android:nextFocusRight="@id/storagePermission"
                    android:nextFocusUp="@id/etUrl"
                    android:nextFocusDown="@id/storagePermission" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
