<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="@dimen/vs_8">

    <TextView
        android:id="@+id/tvName"
        android:layout_width="@dimen/vs_0"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:background="@drawable/button_danmu_setting"
        android:clickable="true"
        android:focusable="true"
        android:ellipsize="end"
        android:gravity="center"
        android:padding="@dimen/vs_10"
        android:singleLine="true"
        android:textColor="@color/dialog_text_primary"
        android:textSize="@dimen/ts_24" />

    <ImageView
        android:id="@+id/btnEdit"
        android:layout_width="@dimen/vs_50"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/vs_5"
        android:layout_marginLeft="@dimen/vs_5"
        android:background="@drawable/button_danmu_setting"
        android:clickable="true"
        android:focusable="true"
        android:padding="@dimen/vs_10"
        android:src="@drawable/icon_edit" />

    <ImageView
        android:id="@+id/btnDelete"
        android:layout_width="@dimen/vs_50"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/vs_5"
        android:layout_marginLeft="@dimen/vs_5"
        android:background="@drawable/button_danmu_setting"
        android:clickable="true"
        android:focusable="true"
        android:padding="@dimen/vs_10"
        android:src="@drawable/icon_delete" />

</LinearLayout>
